<UserControl x:Class="EPIControls.Controls.BaseUserControls.EPIWaferMap3D"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EPIControls.Controls.BaseUserControls"
             mc:Ignorable="d" 
             Background="#10101A"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>

        <!-- 3D Viewport -->
        <Viewport3D x:Name="PART_Viewport"
                    Grid.Row="0"
                    ClipToBounds="True">
            <ModelVisual3D x:Name="PART_SceneVisual"/>
        </Viewport3D>

        <!-- 투명 오버레이: Viewport3D는 빈 영역에서 마우스 이벤트가 안 잡히므로
             이 Rectangle이 항상 마우스 입력을 대신 수신한다 -->
        <Rectangle Grid.Row="0"
                   x:Name="PART_MouseOverlay"
                   Fill="Transparent"
                   MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                   MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                   MouseRightButtonDown="Viewport_MouseRightButtonDown"
                   MouseRightButtonUp="Viewport_MouseRightButtonUp"
                   MouseMove="Viewport_MouseMove"
                   MouseWheel="Viewport_MouseWheel"/>

        <!-- 통계 바 (하단) -->
        <Border Grid.Row="1"
                Background="#141420"
                BorderBrush="#2D2D41"
                BorderThickness="0,1,0,0"
                Padding="14,0,14,0">
            <TextBlock x:Name="PART_StatsText"
                       Foreground="#AABFD7"
                       FontSize="11"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       Text="데이터를 로드하세요."/>
        </Border>
    </Grid>
</UserControl>
