<UserControl x:Class="EPIControls.Controls.BaseUserControls.EPIRndRobot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EPIControls.Controls.BaseUserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="Transparent">
    <UserControl.Resources>

        <!-- 원판: 밝은 중심 → 어두운 테두리로 강한 입체감 -->
        <RadialGradientBrush x:Key="DiskGrad"
                         GradientOrigin="0.38,0.32" Center="0.5,0.5"
                         RadiusX="0.7" RadiusY="0.7">
            <GradientStop Color="#FFFFFF" Offset="0.0"/>
            <GradientStop Color="#DCDCDC" Offset="0.25"/>
            <GradientStop Color="#B4B4B4" Offset="0.5"/>
            <GradientStop Color="#787878" Offset="0.78"/>
            <GradientStop Color="#505050" Offset="1.0"/>
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="Arm1Grad" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#F0F0F0" Offset="0"/>
            <GradientStop Color="#CCCCCC" Offset="0.25"/>
            <GradientStop Color="#9A9A9A" Offset="0.55"/>
            <GradientStop Color="#BEBEBE" Offset="0.8"/>
            <GradientStop Color="#D8D8D8" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="Arm2Grad" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#EBEBEB" Offset="0"/>
            <GradientStop Color="#C5C5C5" Offset="0.25"/>
            <GradientStop Color="#929292" Offset="0.55"/>
            <GradientStop Color="#B8B8B8" Offset="0.8"/>
            <GradientStop Color="#D2D2D2" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="Arm3Grad" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#E4E4E4" Offset="0"/>
            <GradientStop Color="#BCBCBC" Offset="0.25"/>
            <GradientStop Color="#888888" Offset="0.55"/>
            <GradientStop Color="#ADADAD" Offset="0.8"/>
            <GradientStop Color="#C8C8C8" Offset="1"/>
        </LinearGradientBrush>
        <RadialGradientBrush x:Key="JointGrad">
            <GradientStop Color="#E8E8E8" Offset="0"/>
            <GradientStop Color="#A0A0A0" Offset="0.7"/>
            <GradientStop Color="#707070" Offset="1"/>
        </RadialGradientBrush>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="500" Height="500">

            <!-- 그림자 (원판 약간 오른쪽 아래로 오프셋) -->
            <Rectangle Width="440" Height="440"
                 Canvas.Left="40" Canvas.Top="40">
                <Rectangle.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#88000000" Offset="0.6"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- 베이스 원판 -->
            <Rectangle Width="440" Height="440"
                 Canvas.Left="30" Canvas.Top="30"
                 RadiusX="20" RadiusY="20"
                 Fill="{StaticResource DiskGrad}"
                 Stroke="#333333" StrokeThickness="1.5"/>

            <!-- ===== 축 1 – 피벗 J0 (250, 250) ===== -->
            <Canvas Canvas.Left="250" Canvas.Top="250" Width="0" Height="0">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="Arm1Rotate" CenterX="0" CenterY="0" Angle="0"/>
                </Canvas.RenderTransform>

                <Path Stroke="#000000" StrokeThickness="1">
                    <Path.Fill>
                        <StaticResource ResourceKey="Arm1Grad"/>
                    </Path.Fill>
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="0,-70" IsClosed="True">
                                <LineSegment Point="140,-70"/>
                                <ArcSegment  Point="140,70" Size="70,70"
                                         SweepDirection="Clockwise" IsLargeArc="False"/>
                                <LineSegment Point="0,70"/>
                                <ArcSegment  Point="0,-70" Size="70,70"
                                         SweepDirection="Clockwise" IsLargeArc="False"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <Ellipse Width="40" Height="40"
                     Canvas.Left="120" Canvas.Top="-20"
                     Fill="{StaticResource JointGrad}"
                     Stroke="#000000" StrokeThickness="1"/>
                <Ellipse Width="14" Height="14"
                     Canvas.Left="133" Canvas.Top="-7"
                     Fill="#505050" Stroke="#000000" StrokeThickness="0.5"/>

                <!-- ===== 축 2 – 피벗 J1 (140, 0) ===== -->
                <Canvas Canvas.Left="140" Canvas.Top="0" Width="0" Height="0">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="Arm2Rotate" CenterX="0" CenterY="0" Angle="0"/>
                    </Canvas.RenderTransform>

                    <Path Stroke="#000000" StrokeThickness="1">
                        <Path.Fill>
                            <StaticResource ResourceKey="Arm2Grad"/>
                        </Path.Fill>
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="0,-64" IsClosed="True">
                                    <LineSegment Point="135,-64"/>
                                    <ArcSegment  Point="135,64" Size="64,64"
                                             SweepDirection="Clockwise" IsLargeArc="False"/>
                                    <LineSegment Point="0,64"/>
                                    <ArcSegment  Point="0,-64" Size="64,64"
                                             SweepDirection="Clockwise" IsLargeArc="False"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <Ellipse Width="36" Height="36"
                         Canvas.Left="117" Canvas.Top="-18"
                         Fill="{StaticResource JointGrad}"
                         Stroke="#000000" StrokeThickness="1"/>
                    <Ellipse Width="13" Height="13"
                         Canvas.Left="123.5" Canvas.Top="-6.5"
                         Fill="#505050" Stroke="#000000" StrokeThickness="0.5"/>

                    <!-- ===== 축 3 – 피벗 J2 (135, 0) ===== -->
                    <Canvas Canvas.Left="135" Canvas.Top="0" Width="0" Height="0">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="Arm3Rotate" CenterX="0" CenterY="0" Angle="0"/>
                        </Canvas.RenderTransform>

                        <Path Stroke="#000000" StrokeThickness="1">
                            <Path.Fill>
                                <StaticResource ResourceKey="Arm3Grad"/>
                            </Path.Fill>
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="0,-55" IsClosed="True">
                                        <LineSegment Point="130,-55"/>
                                        <LineSegment Point="130,-22"/>
                                        <LineSegment Point="290,-22"/>
                                        <ArcSegment  Point="290,22" Size="22,22"
                                                 SweepDirection="Clockwise" IsLargeArc="False"/>
                                        <LineSegment Point="130,22"/>
                                        <LineSegment Point="130,55"/>
                                        <LineSegment Point="0,55"/>
                                        <ArcSegment  Point="0,-55" Size="55,55"
                                                 SweepDirection="Clockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>

                        <Line X1="130" Y1="-55" X2="130" Y2="55"
                          Stroke="#000000" StrokeThickness="1"/>
                    </Canvas>
                </Canvas>
            </Canvas>

        </Canvas>
    </Viewbox>
</UserControl>
