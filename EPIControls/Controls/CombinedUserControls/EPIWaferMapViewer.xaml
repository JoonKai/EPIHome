<UserControl x:Class="EPIControls.Controls.CombinedUserControls.EPIWaferMapViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EPIControls.Controls.CombinedUserControls"
             xmlns:mycontrol="clr-namespace:EPIControls.Controls.BaseUserControls"
             mc:Ignorable="d" Background="Transparent">
    <Border BorderBrush="DarkGray" BorderThickness=".8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <mycontrol:EPIWaferMap x:Name="WaferMap"
                                   Grid.Column="0" Grid.Row="0"/>

            <mycontrol:EPIWaferMapRange x:Name="WaferMapRange"
                                        Grid.Column="1" Grid.Row="0"/>

            <!-- ✅ 호버 셀 정보 표시 -->
            <Border Grid.Column="0" Grid.Row="1" Grid.RowSpan="2"
                    BorderBrush="DarkGray" BorderThickness=".8"
                    Background="#FF1E1E2E">
                <TextBlock x:Name="HoverInfoText"
                           Foreground="#FFCDD6F4"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           TextWrapping="Wrap"
                           Text="—"/>
            </Border>

            <Border Grid.Column="1" Grid.Row="1" Grid.RowSpan="2"
                    BorderBrush="DarkGray" BorderThickness=".8">
                <TextBlock />
            </Border>
        </Grid>
    </Border>
</UserControl>
