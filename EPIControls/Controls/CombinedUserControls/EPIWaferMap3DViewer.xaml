<UserControl x:Class="EPIControls.Controls.CombinedUserControls.EPIWaferMap3DViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EPIControls.Controls.CombinedUserControls"
             xmlns:map3d="clr-namespace:EPIControls.Controls.BaseUserControls"
             mc:Ignorable="d" 
             Background="Transparent">
    <Border BorderBrush="DarkGray" BorderThickness=".8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <!-- 3D 웨이퍼 맵 -->
            <map3d:EPIWaferMap3D x:Name="WaferMap3D"
                                     Grid.Column="0" Grid.Row="0"/>

            <!-- 컬러 범위 (기존 EPIWaferMapRange 그대로 재사용) -->
            <map3d:EPIWaferMapRange x:Name="WaferMapRange"
                                        Grid.Column="1" Grid.Row="0"/>

            <!-- 호버/선택 셀 정보 표시 (하단) -->
            <Border Grid.Column="0" Grid.Row="1"
                    Grid.ColumnSpan="2"
                    BorderBrush="DarkGray" BorderThickness=".8"
                    Background="#FF1E1E2E">
                <TextBlock x:Name="HoverInfoText"
                           Foreground="#FFCDD6F4"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           TextWrapping="NoWrap"
                           Text="—"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
